<Window x:Class="AutomataSimulator.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:graph="clr-namespace:GraphShape.Controls;assembly=GraphShape.Controls"
        xmlns:models="clr-namespace:AutomataSimulator.WPF.Models"
        Title="Automata Simulator" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Ваш шаблон вершины -->
        <DataTemplate DataType="{x:Type models:VisualVertex}">
            <Grid MouseLeftButtonDown="Vertex_MouseLeftButtonDown" Background="Transparent" Tag="{Binding}">

                <!-- 1. СОСТОЯНИЕ: ОБЫЧНЫЙ УЗЕЛ -->
                <Grid Width="45" Height="45">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDummy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Ellipse StrokeThickness="2">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="White"/>
                                <Setter Property="Stroke" Value="Black"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Fill" Value="#FFD700"/>
                                        <Setter Property="StrokeThickness" Value="4"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFinal}" Value="True">
                                        <Setter Property="Stroke" Value="#E74C3C"/>
                                        <Setter Property="StrokeThickness" Value="3"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>

                    <Ellipse Width="12" Height="12" Fill="Red" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBreakpoint}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>

                <!-- 2. СОСТОЯНИЕ: ФИКТИВНЫЙ УЗЕЛ (Для петель и встречных стрелок) -->
                <!-- Линии будут соединяться ровно с границами этого бордера -->
                <!-- 2. СОСТОЯНИЕ: ФИКТИВНЫЙ УЗЕЛ (Для петель и встречных стрелок) -->
                <Border Background="#FDFEFE" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Padding="4,2" 
        MaxWidth="200" MaxHeight="120">
                    <!-- ОГРАНИЧИЛИ РАЗМЕР -->
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDummy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <!-- Добавили ScrollViewer для прокрутки правил грамматики -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding Name}" Foreground="#2980B9" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DataTemplate>

        <Style TargetType="{x:Type graph:EdgeControl}">
            <Setter Property="ToolTip" Value="{Binding Label}"/>
            <Setter Property="StrokeThickness" Value="4"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#ECF0F1">
        <!-- Добавляем определение строк -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Для меню -->
            <RowDefinition Height="*"/>
            <!-- Для всего остального -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- НОВАЯ ПАНЕЛЬ МЕНЮ (Загрузка / Сохранение) -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="White" Margin="10,10,10,0" CornerRadius="12" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="📂 Загрузить проект" Command="{Binding LoadProjectCommand}" Margin="0,0,10,0" Padding="15,8" Background="#BDC3C7" BorderThickness="0" FontWeight="Bold"/>
                <Button Content="💾 Сохранить проект" Command="{Binding SaveProjectCommand}" Padding="15,8" Background="#2ECC71" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="White" Margin="10" CornerRadius="12" Padding="15">
            <StackPanel>
                <TextBlock Text="Конструктор" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                <TextBox Text="{Binding SourceText, UpdateSourceTrigger=PropertyChanged}" Height="100" AcceptsReturn="True" Margin="0,5,0,10" Padding="5"/>
                <Button Content="Regex -> NFA" Command="{Binding TranslateRegexCommand}" Height="40" Margin="0,0,0,5" Background="#3498DB" Foreground="White" BorderThickness="0"/>
                <Button Content="Преобразовать NFA в DFA" Command="{Binding ConvertToDfaCommand}" Height="30" Margin="0,0,0,10" Background="#F39C12" Foreground="White" BorderThickness="0"/>
                <Button Content="Grammar -> PDA" Command="{Binding TranslateGrammarCommand}" Height="40" Background="#3498DB" Foreground="White" BorderThickness="0"/>
                <Separator Margin="0,20"/>
                <TextBlock Text="Входная строка:"/>
                <TextBox Text="{Binding TestInput, UpdateSourceTrigger=PropertyChanged}" FontSize="20" FontWeight="Bold" Padding="5"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="White" Margin="0,10" CornerRadius="12" ClipToBounds="True">

            <graph:GraphLayout x:Name="GraphLayout" 
                       LayoutAlgorithmType="KK" 
                       OverlapRemovalAlgorithmType="FSA"/>

        </Border>

        <Border Grid.Row="1" Grid.Column="2" Background="White" Margin="10" CornerRadius="12" Padding="15">
            <StackPanel DataContext="{Binding Simulation}">
                <TextBlock Text="Симуляция" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <!-- НОВАЯ ПЛАШКА СТАТУСА -->
                <Border Background="{Binding StatusColor, Mode=OneWay}" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                    <TextBlock Text="{Binding StatusText, Mode=OneWay}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="14"/>
                </Border>

                <TextBlock Text="Прогресс чтения:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border Background="#FDFEFE" BorderBrush="#D5DBDB" BorderThickness="1" Padding="10" Margin="0,0,0,5">
                    <TextBlock FontSize="18" FontFamily="Consolas">
                        <Run Text="{Binding ProcessedText, Mode=OneWay}" Foreground="LightGray" TextDecorations="Strikethrough"/>
                        <Run Text="{Binding RemainingText, Mode=OneWay}" Foreground="Black" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
                <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}" Height="10" Margin="0,0,0,15" Foreground="#2ECC71" Background="#EAFAF1"/>

                <UniformGrid Columns="2" Margin="0,0,0,10">
                    <Button Content="НАЗАД" Click="StepBackward_Click" Height="40" Background="#95A5A6" Foreground="White" FontWeight="Bold" Margin="0,0,2,0" BorderThickness="0"/>
                    <Button Content="ВПЕРЕД" Click="StepForward_Click" Height="40" Background="#2ECC71" Foreground="White" FontWeight="Bold" Margin="2,0,0,0" BorderThickness="0"/>
                    <Button Content="ЗАПУСК" Command="{Binding RunCommand}" Height="40" Background="#9B59B6" Foreground="White" FontWeight="Bold" Margin="0,0,2,0" BorderThickness="0"/>
                </UniformGrid>

                <Button Content="СБРОС В НАЧАЛО" Click="Reset_Click" Height="30" Background="#E74C3C" Foreground="White" BorderThickness="0"/>

                <TextBlock Text="Магазин (Стек):" Margin="0,15,0,5" FontWeight="Bold"/>
                <ListBox ItemsSource="{Binding StackView}" Height="250" Background="#F8F9F9" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>